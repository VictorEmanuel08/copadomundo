# Copie este arquivo para .env e preencha com os seus valores
# cp .env.example .env

# ── Football Data API (placares ao vivo) ──────────────────────────────
# Registro GRATUITO em: https://www.football-data.org/client/register
# Plano Free: 10 chamadas/minuto · Scores com pequeno delay
VITE_FOOTBALL_DATA_TOKEN=

# ── Firebase ──────────────────────────────────────────────────────────
# Copie do Console: console.firebase.google.com → Configurações do projeto
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Push Notifications — VAPID Key (opcional) ─────────────────────────
# Firebase Console → Project Settings → Cloud Messaging
# → Web Push certificates → Gerar par de chaves → copie a chave pública
VITE_FIREBASE_VAPID_KEY=
